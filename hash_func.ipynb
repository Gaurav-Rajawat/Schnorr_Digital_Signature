   "source": [
    "# hash_func.sage\n",
    "\n",
    "import hashlib\n",
    "\n",
    "def hash_function(r, m):\n",
    "    data = str(r) + str(m)\n",
    "    h = hashlib.sha256(data.encode()).hexdigest()\n",
    "    \n",
    "    return Integer(int(h, 16))"
   ]
