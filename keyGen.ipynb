   "source": [
    "# Generation of both private and public key\n",
    "def keygen(p, g):\n",
    "    # Private key\n",
    "    x = randint(1, p-2)\n",
    "    \n",
    "    # Public key\n",
    "    y = power_mod(g, x, p)\n",
    "    \n",
    "    return x, y"
   ]
