   "source": [
    "# sign.sage\n",
    "\n",
    "from hash_func import hash_function\n",
    "\n",
    "def sign(p, g, x, m):\n",
    "    k = randint(1, p-2)\n",
    "    \n",
    "    r = power_mod(g, k, p)\n",
    "    \n",
    "    e = hash_function(r, m)\n",
    "    e = e % (p-1)\n",
    "    \n",
    "    s = (k - x*e) % (p-1)\n",
    "    \n",
    "    return (r, s)"
   ]
